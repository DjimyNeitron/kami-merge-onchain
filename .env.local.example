# Kami Merge — local env template
# Copy to .env.local (which is gitignored) and fill in real values.

# WalletConnect Project ID — get one at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Supabase backend (Phase 4 Chunk 2)
# Project URL — looks like https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon (public) key — safe to expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role (secret) key — server-only, NEVER prefix NEXT_PUBLIC_
# and never reference from any file under src/components/.
SUPABASE_SERVICE_ROLE_KEY=
